# ─── SMTP Server ───────────────────────────────────────────
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=587
SMTP_SECURE=false

# ─── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://smtp_user:your_db_password@localhost:5432/smtp_sender

# ─── Defaults ──────────────────────────────────────────────
DEFAULT_FROM_NAME=Support Team
BOUNCE_RETURN_PATH=bounces@yourdomain.com

# ─── Logging ───────────────────────────────────────────────
LOG_LEVEL=info

# ─── Worker ────────────────────────────────────────────────
POLL_INTERVAL_MS=15000
MAILBOX_THROTTLE_MS=180000
LOCK_TIMEOUT_MINUTES=10
DRY_RUN=false

# ─── Mailbox Credentials (10 slots) ───────────────────────
SMTP_MAILBOX_1_USER=support1@yourdomain.com
SMTP_MAILBOX_1_PASS=mailbox1_password_here

SMTP_MAILBOX_2_USER=support2@yourdomain.com
SMTP_MAILBOX_2_PASS=mailbox2_password_here

SMTP_MAILBOX_3_USER=support3@yourdomain.com
SMTP_MAILBOX_3_PASS=mailbox3_password_here

SMTP_MAILBOX_4_USER=support4@yourdomain.com
SMTP_MAILBOX_4_PASS=mailbox4_password_here

SMTP_MAILBOX_5_USER=support5@yourdomain.com
SMTP_MAILBOX_5_PASS=mailbox5_password_here

SMTP_MAILBOX_6_USER=support6@yourdomain.com
SMTP_MAILBOX_6_PASS=mailbox6_password_here

SMTP_MAILBOX_7_USER=support7@yourdomain.com
SMTP_MAILBOX_7_PASS=mailbox7_password_here

SMTP_MAILBOX_8_USER=support8@yourdomain.com
SMTP_MAILBOX_8_PASS=mailbox8_password_here

SMTP_MAILBOX_9_USER=support9@yourdomain.com
SMTP_MAILBOX_9_PASS=mailbox9_password_here

SMTP_MAILBOX_10_USER=support10@yourdomain.com
SMTP_MAILBOX_10_PASS=mailbox10_password_here
